FROM rust:slim AS builder

WORKDIR /usr/src/app

COPY Cargo.toml Cargo.lock ./
COPY rust-graph-types ./rust-graph-types
COPY rust-graph-api ./rust-graph-api

WORKDIR /usr/src/app/rust-graph-api

# Accept custom hardware optimization flags dynamically
ARG CUSTOM_RUSTFLAGS=""
ENV RUSTFLAGS="${CUSTOM_RUSTFLAGS}"

RUN cargo build --release

# Distroless 'cc' image includes glibc and libgcc, required by standard Rust builds
FROM gcr.io/distroless/cc-debian12:nonroot

WORKDIR /app
COPY graph.rkyv /app/graph.rkyv
COPY --from=builder /usr/src/app/target/release/rust-graph-api /app/rust-graph-api

CMD ["./rust-graph-api"]
